# ─────────────────────────────────────────────
# SafeSave Backend — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# App
ENVIRONMENT=production
DEBUG=false
MAINTENANCE_MODE=false

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///./safesave.db
# Production (PostgreSQL — recommended):
# DATABASE_URL=postgresql://user:password@localhost:5432/safesave_db

# PayHero — https://docs.payhero.co.ke/docs/authorization
# PAYHERO_API_KEY is the full Basic auth token from your PayHero dashboard (API Keys menu)
PAYHERO_API_KEY=your_basic_auth_token_from_payhero_dashboard
PAYHERO_API_SECRET=your_api_secret_kept_for_reference
PAYHERO_BASE_URL=https://backend.payhero.co.ke/api/v2
# PAYHERO_BASE_URL=https://sandbox.payhero.io/api/v2   # sandbox
PAYHERO_CHANNEL_ID=6151
PAYHERO_WEBHOOK_SECRET=your_webhook_hmac_secret

# Webhook — public URL PayHero will POST callbacks to
WEBHOOK_URL=https://yourdomain.com/webhooks/payhero

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Frontend CORS
FRONTEND_URL=https://yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/safesave.log

# Email (optional — for future notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@safesave.com

# Business Rules
MIN_DEPOSIT=100
MAX_DEPOSIT=1000000
VIP_MINIMUM_DEPOSIT=5000

# Branding
APP_NAME=SafeSave
COMPANY_NAME=SafeSave Ltd
CUSTOMER_SUPPORT_EMAIL=support@safesave.com
CUSTOMER_SUPPORT_PHONE=+254712345678

# DB credentials (used by docker-compose)
DB_NAME=safesave_db
DB_USER=safesave
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_PORT=5432
