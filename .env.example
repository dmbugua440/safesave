# FastAPI Configuration
ENVIRONMENT=production
DEBUG=false

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./safesave.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/safesave_db

# Pay Hero API Configuration
PAYHERO_API_KEY=your_payhero_api_key_here
PAYHERO_API_SECRET=your_payhero_api_secret_here
PAYHERO_WEBHOOK_SECRET=your_webhook_secret_for_verification
PAYHERO_BASE_URL=https://api.payhero.io/api/v2
# PAYHERO_BASE_URL=https://sandbox.payhero.io/api/v2  # For testing

# Webhook Configuration
WEBHOOK_URL=https://yourdomain.com/webhooks/payhero
WEBHOOK_SECRET=your_webhook_secret_key

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/safesave.log

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@safesave.com

# Business Configuration
MIN_DEPOSIT=100
MAX_DEPOSIT=1000000
VIP_MINIMUM_DEPOSIT=5000
VIP_BENEFITS_MULTIPLIER=1.5

# App Branding
APP_NAME=SafeSave
COMPANY_NAME=SafeSave Ltd
CUSTOMER_SUPPORT_EMAIL=support@safesave.com
CUSTOMER_SUPPORT_PHONE=+254712345678
